    "help": {
      "title": "Help & Support",
      "sections": {
        "booking": {
          "title": "BOOKING ISSUES",
          "items": [
            {
              "q": "How do I book a ride?",
              "a": "Tap Cab, Truck, or Ambulance on the home screen. Enter your pickup and drop location, select your vehicle type, and tap Confirm."
            },
            {
              "q": "Can I schedule a ride in advance?",
              "a": "Currently bogie supports instant bookings only. Scheduled rides are coming soon."
            },
            {
              "q": "Why can't I find a driver?",
              "a": "No drivers may be available in your area right now. Try again in a few minutes or adjust your pickup location slightly."
            }
          ]
        },
        "payments": {
          "title": "PAYMENTS",
          "items": [
            {
              "q": "What payment methods are accepted?",
              "a": "Cash, UPI (Google Pay, PhonePe, Paytm), Credit/Debit cards, and bogie Wallet."
            },
            {
              "q": "I was charged incorrectly.",
              "a": "Raise a dispute within 24 hours: Help → Payment Issue → Wrong Charge. Our team will review and respond within 2 business days."
            },
            {
              "q": "How do I get a refund?",
              "a": "Approved refunds are processed in 5–7 business days back to your original payment method."
            }
          ]
        },
        "cancellations": {
          "title": "CANCELLATIONS",
          "items": [
            {
              "q": "How do I cancel a booking?",
              "a": "Open the active booking screen and tap Cancel. Cancellation within 2 minutes is free; a small fee of ₹30–₹50 may apply after that."
            },
            {
              "q": "My driver cancelled. What happens?",
              "a": "We will automatically try to match you with another driver. If unavailable, a full refund is processed immediately."
            }
          ]
        },
        "truck": {
          "title": "TRUCK BOOKINGS",
          "items": [
            {
              "q": "What items cannot be transported?",
              "a": "Weapons, explosives, drugs, illegal items, live animals without permits, and human remains without proper documentation."
            },
            {
              "q": "Is my cargo insured?",
              "a": "Basic protection is included. You can purchase full cargo insurance at the time of booking for complete cover."
            }
          ]
        },
        "ambulance": {
          "title": "AMBULANCE",
          "items": [
            {
              "q": "Is the free ambulance really free?",
              "a": "Yes — it is government/NGO sponsored. Subject to availability. Response time is not guaranteed. For life-threatening emergencies, always call 108 first."
            },
            {
              "q": "What is included in a paid BLS ambulance?",
              "a": "Trained paramedic, oxygen cylinder, first aid kit, stretcher, and basic patient monitoring equipment."
            }
          ]
        }
      },
      "contactTitle": "Still need help?",
      "contactSub": "Our support team is available 8 AM – 10 PM daily",
      "contactBtn": "Email Support"
    },
